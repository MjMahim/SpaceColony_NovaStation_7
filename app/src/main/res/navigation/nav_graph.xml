<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.spacecolony.ui.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_recruit"
            app:destination="@id/recruitFragment" />
    </fragment>

    <fragment
        android:id="@+id/quartersFragment"
        android:name="com.spacecolony.ui.QuartersFragment"
        android:label="Quarters"
        tools:layout="@layout/fragment_quarters">
        <action
            android:id="@+id/action_quarters_to_recruit"
            app:destination="@id/recruitFragment" />
    </fragment>

    <fragment
        android:id="@+id/simulatorFragment"
        android:name="com.spacecolony.ui.SimulatorFragment"
        android:label="Simulator"
        tools:layout="@layout/fragment_simulator" />

    <fragment
        android:id="@+id/missionControlFragment"
        android:name="com.spacecolony.ui.MissionControlFragment"
        android:label="Mission Control"
        tools:layout="@layout/fragment_mission_control" />

    <fragment
        android:id="@+id/statisticsFragment"
        android:name="com.spacecolony.ui.StatisticsFragment"
        android:label="Statistics"
        tools:layout="@layout/fragment_statistics" />

    <fragment
        android:id="@+id/medbayFragment"
        android:name="com.spacecolony.ui.MedbayFragment"
        android:label="Medbay"
        tools:layout="@layout/fragment_medbay" />

    <fragment
        android:id="@+id/recruitFragment"
        android:name="com.spacecolony.ui.RecruitFragment"
        android:label="Recruit"
        tools:layout="@layout/fragment_recruit" />

</navigation>
