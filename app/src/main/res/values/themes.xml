<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SpaceColony" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <!-- Secondary/accent color -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBottomNav</item>
        <!-- Window background -->
        <item name="android:windowBackground">@color/colorBackground</item>
        <!-- Surface colors -->
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorTextPrimary</item>
        <item name="colorOnBackground">@color/colorTextPrimary</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/colorTextPrimary</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>
        <!-- Bottom navigation -->
        <item name="bottomNavigationStyle">@style/Widget.SpaceColony.BottomNavigation</item>
        <!-- Card style -->
        <item name="materialCardViewStyle">@style/Widget.SpaceColony.CardView</item>
        <!-- Button style -->
        <item name="materialButtonStyle">@style/Widget.SpaceColony.Button</item>
        <!-- Shape appearance -->
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.SpaceColony.MediumComponent</item>
    </style>

    <style name="Widget.SpaceColony.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/colorBottomNav</item>
        <item name="itemIconTint">@color/bottom_nav_color_selector</item>
        <item name="itemTextColor">@color/bottom_nav_color_selector</item>
    </style>

    <style name="Widget.SpaceColony.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorCard</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="Widget.SpaceColony.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.SpaceColony.Button.Accent" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorAccent</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.SpaceColony.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/colorAccent</item>
        <item name="android:textColor">@color/colorAccent</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="ShapeAppearance.SpaceColony.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="TextAppearance.SpaceColony.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.SpaceColony.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>

    <style name="TextAppearance.SpaceColony.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>

    <style name="TextAppearance.SpaceColony.Count" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/colorAccent</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.SpaceColony.ProgressBar.Green" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:progressTint">@color/colorEnergyGreen</item>
        <item name="android:progressBackgroundTint">@color/colorDivider</item>
    </style>

    <style name="Widget.SpaceColony.ProgressBar.Red" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:progressTint">@color/colorThreat</item>
        <item name="android:progressBackgroundTint">@color/colorDivider</item>
    </style>
</resources>
